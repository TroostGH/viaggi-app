// Regole di sicurezza Firestore per "viaggi-app"
// Modalità "single user, no login": chiunque conosca l'URL del sito può leggere e scrivere.
// La sicurezza viene dal fatto che l'URL non è pubblico.
//
// Quando vorrai aggiungere il login (Firebase Auth), sostituisci le righe `allow ...: if true;`
// con `allow read, write: if request.auth != null && request.auth.uid == "IL_TUO_UID";`
//
// Per applicare: Firebase Console → Firestore Database → Rules → incolla qui sotto → Publish.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Collezione 'trips' (un documento per viaggio)
    match /trips/{tripId} {
      allow read, write: if true;
    }

    // Tutto il resto è negato di default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
